# =========================================================
# AI 智能绘图与编辑插件配置文件 (WAuxiliary)
# 修改后请在 WAuxiliary 中重启/重新加载插件以生效
# =========================================================

# 1. 中转 API 的基础地址 (可自己添加已有的 API 中转站)
# 例如: https://yunwu.ai
api_base_url=https://yunwu.ai

# 2. 您的中转平台 API Key (通常以 sk- 开头)
api_key=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 3. 统一 AI 绘图与编辑设置 (文生图与图生图共用相同画质比例与模型)
# 默认使用 Gemini 旗舰级多模态图像生成/编辑模型
model=gemini-3.1-flash-image-preview
# 统一分辨率级别: 1K (标准), 2K (高清), 4K (超清)
resolution_level=1K
# 统一画面比例: 自动, 1:1, 9:16, 16:9, 21:9, 2:3, 3:2, 3:4, 4:3, 4:5, 5:4, 1:4, 4:1, 1:8, 8:1, ⚙️ 手动输入自定义分辨率/比例
aspect_ratio=自动
# 只有在选择“手动输入自定义分辨率/比例”时，下面的自定义尺寸才会生效
size=1024x1024

# 4. 指令触发词
trigger_word=#生图
edit_trigger_word=#编辑图

# 5. 【高级功能】动态模型切换提示
# 插件已支持在微信指令中通过横杠（-）动态临时切换模型，格式如下：
# - 文生图格式: #生图-[模型名称] [提示词]  (例如: #生图-gemini-3-pro-image-preview 一只帅气的猫咪)
# - 变图/编辑格式: #编辑图-[模型名称] [修改指令] (例如: #编辑图-gemini-2.5-flash-image 变成水彩风格)
